<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Calibi Sync — Your rhythm. Your wellness. In sync.</title>
<meta name="description" content="Track your cycle (with phase insights), log workouts, count macros, journal, and keep a Face ID–protected progress gallery. iOS only, 16+. Free 7-day trial." />
<meta name="theme-color" content="#FFFFFF" />
<link rel="icon" href="/favicon.ico" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet" />

<style>
:root{
--pink:#E6A9A7; /* pink (cards/shadows) */
--sage:#A3C4A8; /* primary accent (buttons, FAQ highlights) */
--text:#2B2B2B; /* brown heading/body */
--text-2:#4A4A4A; /* secondary copy */
--white:#FFFFFF;
--radius:16px;
--container:1100px;
}

/* Base */
*{box-sizing:border-box}
html,body{margin:0;padding:0}
body{
background:var(--white);
color:var(--text);
font:16px/1.6 "Poppins",system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
-webkit-font-smoothing:antialiased; text-rendering:optimizeLegibility;
}
img{max-width:100%;height:auto;display:block}

/* Layout */
.container{max-width:var(--container); margin:0 auto; padding:0 20px;}
header{
background:#fff; border-bottom:1px solid rgba(0,0,0,.06);
position:sticky; top:0; z-index:10;
}
.nav{display:flex; align-items:center; justify-content:space-between; height:78px;}
.brand{
display:flex; align-items:center; gap:12px; text-decoration:none; color:var(--text);
}
.brand img{width:40px; height:40px; border-radius:10px;}
.brand-title{
font-weight:800; letter-spacing:-.01em;
font-size: clamp(20px, 2.2vw, 26px); /* bigger brand name */
line-height:1;
}
.menu{display:flex; gap:20px; align-items:center;}
.menu a{color:var(--text); text-decoration:none; font-weight:600;}
.menu a:hover{opacity:.85}

/* Hero */
.hero{padding:56px 0 28px}
.badge{
display:inline-flex; align-items:center; gap:.5rem;
padding:6px 10px; border-radius:999px;
background:rgba(163,196,168,.12);
border:1px solid rgba(163,196,168,.25);
font-weight:600; font-size:.9rem; color:var(--text);
}
.hero-grid{
display:grid; gap:32px; grid-template-columns:1.1fr .9fr; align-items:center;
}
h1{
font-family:"Playfair Display",serif;
font-size:clamp(36px,5vw,58px);
line-height:1.1; margin:16px 0 12px; letter-spacing:-.015em; color:var(--text);
}
.lead{color:var(--text-2); margin:0 0 16px;}
.cta{display:flex; gap:12px; flex-wrap:wrap}

/* Buttons (both solid sage) */
.btn{
display:inline-flex; align-items:center; justify-content:center;
border:none; border-radius:999px; padding:14px 20px;
font-weight:700; text-decoration:none; color:#fff;
background:var(--sage); box-shadow:0 6px 18px rgba(163,196,168,.32);
transition:transform .15s ease, box-shadow .15s ease, opacity .15s ease;
}
.btn:hover{transform:translateY(-1px)}
.btn:active{transform:translateY(0)}
.btn:focus-visible{outline:3px solid rgba(163,196,168,.55); outline-offset:2px}

/* Hero visuals */
.hero-visual{
background:#fff; border-radius:24px; padding:20px;
border:1px solid rgba(234,181,161,.35);
box-shadow:0 12px 32px rgba(234,181,161,.18);
}
.visual-inner{
aspect-ratio:1/1; border-radius:20px; display:grid; place-items:center;
background:linear-gradient(135deg, rgba(234,181,161,.30), rgba(163,196,168,.35));
overflow:hidden;
}
.visual-inner img{
width:66%; max-width:420px; height:auto; object-fit:contain;
filter: drop-shadow(0 10px 24px rgba(0,0,0,.05));
}

/* Gradient divider */
.divider{
height:2px; margin:32px 0 0;
background:linear-gradient(90deg, transparent, var(--pink), var(--sage), transparent);
border-radius:2px;
}

/* Sections */
section{padding:44px 0}
h2{
font-family:"Playfair Display",serif;
font-size:clamp(24px,3.6vw,36px);
margin:0 0 12px; color:var(--text);
}

/* Features */
.features{display:grid; gap:16px; grid-template-columns:repeat(auto-fit, minmax(260px,1fr));}
.card{
background:#fff; padding:20px; border-radius:var(--radius);
border:1px solid rgba(234,181,161,.40);
box-shadow:0 8px 24px rgba(234,181,161,.18);
}
.card h3{margin:0 0 6px; font-size:1.05rem; color:var(--text);}
.card p{margin:0; color:var(--text-2);}
.strip{
margin-top:20px; padding:18px; color:var(--text-2);
border:1px solid rgba(234,181,161,.40); border-radius:14px;
box-shadow:0 10px 28px rgba(234,181,161,.16);
}

/* FAQ (sage theme, no pink outlines) */
.faq{padding:56px 0; border-top:1px solid rgba(0,0,0,.06);}
.faq-grid{max-width:900px; margin:12px auto 0; display:grid; gap:12px;}
details{
border-radius:14px; background:rgba(163,196,168,.10); /* sage wash */
border:1px solid rgba(163,196,168,.30); /* sage border */
padding:14px 16px;
transition:box-shadow .15s ease, background .15s ease;
}
details[open]{background:rgba(163,196,168,.14); box-shadow:0 10px 26px rgba(163,196,168,.18);}
summary{
list-style:none; cursor:pointer; display:flex; align-items:center; gap:10px;
font-weight:700; color:var(--text);
}
summary::-webkit-details-marker{display:none}
.faq-qicon{
width:28px; height:28px; border-radius:999px; flex:0 0 28px;
display:grid; place-items:center; background:rgba(163,196,168,.22);
color:#1d3a29; font-weight:800; font-size:.9rem;
}
.faq-a{margin:10px 2px 2px; color:var(--text-2);}

/* Policies */
.policy{padding:56px 0; border-top:1px solid rgba(0,0,0,.06);}
.policy p{max-width:900px; margin:0 auto 16px; color:var(--text-2);}

/* Footer */
footer{padding:32px 0 48px; border-top:1px solid rgba(0,0,0,.06); color:var(--text-2);}
footer a{color:var(--text); text-decoration:none; font-weight:600}
footer a:hover{opacity:.85}

/* Responsive */
@media (max-width: 900px){ .hero-grid{grid-template-columns:1fr} }
</style>
</head>
<body>
<!-- Header -->
<header>
<div class="container nav">
<a class="brand" href="#">
<!-- Small header logo -->
<img src="logo.png" alt="Calibi Sync logo">
<span class="brand-title">Calibi Sync</span>
</a>
<nav class="menu">
<a href="#features">Features</a>
<a href="#faq">FAQ</a>
<a href="#pricing">Pricing</a>
<a href="#privacy">Privacy</a>
<a href="#terms">Terms</a>
</nav>
</div>
</header>

<!-- Hero -->
<section class="hero">
<div class="container">
<span class="badge">iOS only · 16+</span>
<div class="hero-grid">
<div>
<h1>Your rhythm. Your wellness. In sync.</h1>
<p class="lead">Track your cycle (with phase insights), log workouts, count macros, journal, and keep a Face ID–protected progress gallery.</p>
<p class="lead">Free 7-day trial, then subscribe to continue.</p>
<div class="cta">
<a class="btn" href="https://apps.apple.com/">Start Syncing on the App Store</a>
<a class="btn" href="#features">See Features</a>
</div>
<div class="divider"></div>
</div>

<!-- Large hero logo with soft gradient backdrop -->
<div class="hero-visual">
<div class="visual-inner">
<!-- Replace with your 1200×1200 master logo -->
<img src="/d%20(1200%20x%201200%20px)%20-%201.png" alt="Calibi Sync brand mark">
</div>
</div>
</div>
</div>
</section>

<!-- Features -->
<section id="features">
<div class="container">
<h2>Designed to sync with you</h2>
<div class="features">
<article class="card"><h3>Cycle Tracking</h3><p>Phase insights tailored to your rhythm.</p></article>
<article class="card"><h3>Workout Logs</h3><p>Track sessions, sets/reps/weights, and rest.</p></article>
<article class="card"><h3>Macro Counting</h3><p>Dial in protein, carbs, and fats to your goals.</p></article>
<article class="card"><h3>Journaling</h3><p>Reflect with prompts and notes by cycle phase.</p></article>
<article class="card"><h3>Progress Gallery</h3><p>Face ID + privacy mode to keep photos secure.</p></article>
<article class="card"><h3>Insights</h3><p>Weekly fitness & food tips that adapt to your phase.</p></article>
</div>
<div class="strip" id="pricing"><strong>Membership ·</strong> Free for 7 days, then subscribe monthly or yearly. Cancel anytime.</div>
</div>
</section>

<!-- FAQ (sage theme, no pink outline) -->
<section class="faq" id="faq">
<div class="container">
<h2>FAQ</h2>
<div class="faq-grid">
<details>
<summary><span class="faq-qicon">?</span>Is Calibi Sync free?</summary>
<div class="faq-a">Yes. You get a 7-day free trial. After that, choose a monthly or yearly plan. Cancel anytime in your App Store settings.</div>
</details>
<details>
<summary><span class="faq-qicon">?</span>Is my data private?</summary>
<div class="faq-a">Absolutely. Your logs and photos are stored securely and accessible only to you. We never sell your data.</div>
</details>
<details>
<summary><span class="faq-qicon">?</span>Android support?</summary>
<div class="faq-a">We’re focused on the best iOS experience first (iOS 16+). Android is on our roadmap.</div>
</details>
<details>
<summary><span class="faq-qicon">?</span>Can I export or delete my data?</summary>
<div class="faq-a">Yes. Export or request deletion from the in-app Settings or email us at support@calibisync.com.</div>
</details>
<details>
<summary><span class="faq-qicon">?</span>Does it work offline?</summary>
<div class="faq-a">You can view previously synced data offline. New entries need a connection to sync to your account.</div>
</details>
</div>
</div>
</section>

<!-- Privacy -->
<section class="policy" id="privacy">
<div class="container">
<h2>Privacy Policy</h2>
<p>We collect only what’s needed to provide features like cycle tracking, workout logging, and secure photo storage. Account data (e.g., email) and usage logs are stored securely. Your entries and photos are never sold or shared without consent.</p>
<p>You may request data export or deletion any time via the app’s Settings or by emailing <strong>support@calibisync.com</strong>. We use limited cookies and anonymized analytics to improve performance.</p>
<p>By using Calibi Sync, you agree to this policy. We’ll update this page if our practices change.</p>
</div>
</section>

<!-- Terms -->
<section class="policy" id="terms">
<div class="container">
<h2>Terms of Service</h2>
<p>By using Calibi Sync, you agree to these terms. The app and website are provided “as is.” Subscriptions renew automatically unless cancelled through the App Store before renewal.</p>
<p>You may not reverse-engineer, redistribute, or copy the app or its contents. All intellectual property belongs to Calibi Sync LLC.</p>
<p>We may update these terms as our services evolve. Continued use after changes indicates acceptance. For questions, contact <strong>support@calibisync.com</strong>.</p>
</div>
</section>

<!-- Footer -->
<footer>
<div class="container" style="display:flex; flex-wrap:wrap; gap:12px; align-items:center; justify-content:space-between;">
<div style="display:flex; align-items:center; gap:10px;">
<img src="Untitled%20design.PNG" width="43" height="42" alt="" style="border-radius:6px">
<strong>Calibi Sync</strong>
</div>
<div style="display:flex; gap:16px; flex-wrap:wrap;">
<a href="#features">Features</a>
<a href="#faq">FAQ</a>
<a href="#privacy">Privacy</a>
<a href="#terms">Terms</a>
</div>
<div style="opacity:.75; width:100%; margin-top:8px;">© <span id="year"></span> Calibi Sync. All rights reserved.</div>
</div>
</footer>

