<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Calibi Sync — Your rhythm. Your wellness. In sync.</title>
<meta name="description" content="Track your cycle (with phase insights), log workouts, count macros, journal, and keep a Face ID–protected progress gallery. iOS only, 16+. Free 7-day trial." />
<meta name="theme-color" content="#FFFFFF" />
<link rel="icon" href="/favicon.ico" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet" />

<style>
:root{
--pink:#EAB5A1; /* blush accent (cards/shadows) */
--sage:#A3C4A8; /* primary accent (buttons, FAQ highlights) */
--text:#2B2B2B; /* brown heading/body */
--text-2:#4A4A4A; /* secondary copy */
--white:#FFFFFF;
--radius:16px;
--container:1100px;
}

*{box-sizing:border-box}
html,body{margin:0;padding:0}
body{
background:var(--white);
color:var(--text);
font:16px/1.6 "Poppins",system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
-webkit-font-smoothing:antialiased; text-rendering:optimizeLegibility;
}
img{max-width:100%;height:auto;display:block}
a{color:var(--text); text-decoration:none}

/* Layout */
.container{max-width:var(--container); margin:0 auto; padding:0 20px;}
header{
background:#fff; border-bottom:1px solid rgba(0,0,0,.06);
position:sticky; top:0; z-index:50;
}
.nav{display:flex; align-items:center; justify-content:space-between; gap:12px; height:78px;}
.brand{display:flex; align-items:center; gap:12px; flex:1 1 auto; min-width:0;}
.brand img{width:48px; height:48px; border-radius:10px;}
.brand-title{font-weight:800; letter-spacing:-.01em; font-size: clamp(20px, 2.2vw, 26px); line-height:1;}
.menu{display:flex; gap:20px; align-items:center; flex:0 0 auto;}
.menu a{font-weight:600; white-space:nowrap;}
.menu a:hover{opacity:.85}

/* Hamburger (hidden on desktop) */
.menu-toggle{display:none; border:0; background:#fff; padding:8px; border-radius:8px; font-size:26px; line-height:1;}
.menu-toggle:focus-visible{outline:3px solid rgba(163,196,168,.55); outline-offset:2px;}

/* Backdrop + Mobile drawer (hidden by default) */
.scrim{
position:fixed; inset:0; background:rgba(0,0,0,.35);
opacity:0; pointer-events:none; transition:opacity .18s ease; z-index:60;
}
.scrim[data-open="true"]{opacity:1; pointer-events:auto}
.mobile-menu{
position:fixed; top:0; right:0; bottom:0; width:min(80vw,360px);
background:#fff; border-left:1px solid rgba(0,0,0,.06);
transform:translateX(100%); transition:transform .22s ease;
padding:16px; display:flex; flex-direction:column; gap:8px; z-index:70;
}
.mobile-menu[data-open="true"]{transform:none}
.mobile-menu__head{display:flex; align-items:center; justify-content:space-between; margin-bottom:6px;}
.mobile-menu a{padding:12px 6px; font-weight:700; color:var(--text);}
.menu-close{border:0; background:#fff; font-size:22px; line-height:1; padding:6px; border-radius:8px;}

/* Hero */
.hero{padding:56px 0 28px}
.badge{
display:inline-flex; align-items:center; gap:.5rem;
padding:6px 10px; border-radius:999px;
background:rgba(163,196,168,.12);
border:1px solid rgba(163,196,168,.25);
font-weight:600; font-size:.9rem; color:var(--text);
}
.hero-grid{display:grid; gap:32px; grid-template-columns:1.1fr .9fr; align-items:center;}
h1{
font-family:"Playfair Display",serif;
font-size:clamp(36px,5vw,58px);
line-height:1.1; margin:16px 0 12px; letter-spacing:-.015em; color:var(--text);
}
.lead{color:var(--text-2); margin:0 0 16px;}
.cta{display:flex; gap:12px; flex-wrap:wrap}

/* Button (single CTA) */
.btn{
display:inline-flex; align-items:center; justify-content:center;
border:none; border-radius:999px; padding:14px 20px;
font-weight:700; color:#fff; background:var(--sage);
box-shadow:0 6px 18px rgba(163,196,168,.32);
transition:transform .15s ease, box-shadow .15s ease, opacity .15s ease;
}
.btn:hover{transform:translateY(-1px)}
.btn:active{transform:translateY(0)}
.btn:focus-visible{outline:3px solid rgba(163,196,168,.55); outline-offset:2px}

/* Hero visuals */
.hero-visual{
background:#fff; border-radius:24px; padding:20px;
border:1px solid rgba(234,181,161,.35);
box-shadow:0 12px 32px rgba(234,181,161,.18);
}
.visual-inner{
aspect-ratio:1/1; border-radius:20px; display:grid; place-items:center;
background:linear-gradient(135deg, rgba(234,181,161,.30), rgba(163,196,168,.35));
overflow:hidden;
}
.visual-inner img{width:66%; max-width:420px; filter:drop-shadow(0 10px 24px rgba(0,0,0,.05));}

/* Gradient divider */
.divider{
height:2px; margin:32px 0 0;
background:linear-gradient(90deg, transparent, var(--pink), var(--sage), transparent);
border-radius:2px;
}

/* Sections */
section{padding:44px 0}
h2{
font-family:"Playfair Display",serif;
font-size:clamp(24px,3.6vw,36px);
margin:0 0 12px; color:var(--text);
}

/* Features */
.features{display:grid; gap:16px; grid-template-columns:repeat(auto-fit, minmax(260px,1fr));}
.card{
background:#fff; padding:20px; border-radius:var(--radius);
border:1px solid rgba(234,181,161,.40);
box-shadow:0 8px 24px rgba(234,181,161,.18);
}
.card h3{margin:0 0 6px; font-size:1.05rem; color:var(--text);}
.card p{margin:0; color:var(--text-2);}
.strip{
margin-top:20px; padding:18px; color:var(--text-2);
border:1px solid rgba(234,181,161,.40); border-radius:14px;
box-shadow:0 10px 28px rgba(234,181,161,.16);
}

/* FAQ (sage theme) */
.faq{padding:56px 0; border-top:1px solid rgba(0,0,0,.06);}
.faq-grid{max-width:900px; margin:12px auto 0; display:grid; gap:12px;}
details{
border-radius:14px; background:rgba(163,196,168,.10);
border:1px solid rgba(163,196,168,.30);
padding:14px 16px; transition:box-shadow .15s ease, background .15s ease;
}
details[open]{background:rgba(163,196,168,.14); box-shadow:0 10px 26px rgba(163,196,168,.18);}
summary{list-style:none; cursor:pointer; display:flex; align-items:center; gap:10px; font-weight:700; color:var(--text);}
summary::-webkit-details-marker{display:none}
.faq-qicon{width:28px; height:28px; border-radius:999px; display:grid; place-items:center; background:rgba(163,196,168,.22); color:#1d3a29; font-weight:800; font-size:.9rem;}
.faq-a{margin:10px 2px 2px; color:var(--text-2);}

/* Policies */
.policy{padding:56px 0; border-top:1px solid rgba(0,0,0,.06);}
.policy p{max-width:900px; margin:0 auto 16px; color:var(--text-2);}

/* Footer */
footer{padding:32px 0 48px; border-top:1px solid rgba(0,0,0,.06); color:var(--text-2);}
footer a{font-weight:600}
footer a:hover{opacity:.85}

/* Breakpoints */
@media (max-width: 900px){ .hero-grid{grid-template-columns:1fr} }
@media (max-width: 820px){ .brand-title{font-size:clamp(18px,5vw,22px);} }
@media (max-width: 600px){
.menu{display:none;} /* hide desktop links */
.menu-toggle{display:inline-flex;}
}
@media (min-width: 601px){
.mobile-menu{display:none !important;}
.scrim{display:none !important;}
}
</style>
</head>
